Subject: [PATCH 1/9] feat: treesitter injections

---
 after/queries/c/injections.scm    | 27 +++++++++++++++++++++++++++
 after/queries/cpp/injections.scm  | 27 +++++++++++++++++++++++++++
 after/queries/html/injections.scm | 14 ++++++++++++++
 3 files changed, 68 insertions(+)
 create mode 100644 after/queries/c/injections.scm
 create mode 100644 after/queries/cpp/injections.scm
 create mode 100644 after/queries/html/injections.scm

diff --git a/after/queries/c/injections.scm b/after/queries/c/injections.scm
new file mode 100644
index 0000000..1f98106
--- /dev/null
+++ b/after/queries/c/injections.scm
@@ -0,0 +1,27 @@
+; Doxygen injection for C
+; Place this file at: after/queries/c/injections.scm
+; (inside your Neovim config, e.g. ~/.config/nvim/after/queries/c/injections.scm)
+
+; Match /** ... */ block comments (Doxygen-style)
+((comment) @injection.content
+  (#match? @injection.content "^/[*][*]")
+  (#set! injection.language "doxygen")
+  (#set! injection.include-children))
+
+; Match /*! ... */ block comments (Qt-style Doxygen)
+((comment) @injection.content
+  (#match? @injection.content "^/[*]!")
+  (#set! injection.language "doxygen")
+  (#set! injection.include-children))
+
+; Match ///  line comments (triple-slash Doxygen)
+((comment) @injection.content
+  (#match? @injection.content "^///")
+  (#set! injection.language "doxygen")
+  (#set! injection.include-children))
+
+; Match //! line comments (Qt-style Doxygen line comments)
+((comment) @injection.content
+  (#match? @injection.content "^//!")
+  (#set! injection.language "doxygen")
+  (#set! injection.include-children))
